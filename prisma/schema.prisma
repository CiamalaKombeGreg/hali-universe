generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AbilityNodeType {
  SYSTEM
  SUBSYSTEM
  ABILITY
  ASSOCIATION_SYSTEM
  ASSOCIATION_ABILITY
}

enum AbilityFamilyType {
  BODY_ALTERATION
  EXTERNAL_MANIPULATION
  MENTAL_PERCEPTUAL
  SPIRITUAL_SOUL
  CREATION_SUMMONING
  CONCEPTUAL_ABSTRACT
  METAPOWER
  DIMENSIONAL_MOVEMENT
  DEFENSE_NEGATION
  UTILITY_SUPPORT
}

enum AbilityNodeStatus {
  DRAFT
  PUBLISHED
}

enum WorldEntryType {
  UNIVERSE
  SERIES_COLLECTION
  CONTINUITY
  INSTALLMENT
  SPINOFF
  FANMADE
  ORIGINAL_CREATION
  CROSSOVER
}

enum WorldCanonStatus {
  CANON
  SEMI_CANON
  NON_CANON
  ALTERNATE_CANON
}

enum WorldCosmologyType {
  SINGLE_UNIVERSE
  MULTIVERSE
  COMPLEX_MULTIVERSE
  HIGHER_DIMENSIONAL_STRUCTURE
}

enum WorldVisibilityStatus {
  DRAFT
  PUBLISHED
}

enum LocationType {
  WORLD
  PLANET
  CONTINENT
  COUNTRY
  REGION
  CITY
  BUILDING
  ARENA
  REALM
  POCKET_DIMENSION
  CONCEPTUAL_SPACE
}

enum LocationOriginType {
  ORIGINAL
  CANON
  SPINOFF_DERIVED
}

enum ArchiveEntryType {
  LOREBOOK
  NOVEL
}

enum ArchiveVisibilityStatus {
  DRAFT
  PUBLISHED
}

enum NovelChapterStatus {
  DRAFT
  PUBLISHED
}

enum GalleryImageSourceType {
  UPLOADED
  EXTERNAL
}

model GalleryPortfolio {
  id        String         @id @default(cuid())
  name      String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  images    GalleryImage[]

  @@index([name])
}

model GalleryImage {
  id          String           @id @default(cuid())
  portfolioId String
  portfolio   GalleryPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  title        String?
  altText      String?
  externalLink String?

  sourceType GalleryImageSourceType
  imageUrl   String
  storageKey String?

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([portfolioId, sortOrder])
  @@index([title])
  @@index([altText])
}

model ArchiveImage {
  id         String   @id @default(cuid())
  url        String
  storageKey String?
  caption    String?
  altText    String?
  isPrimary  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  lorebookCoverFor Lorebook?     @relation("LorebookCover")
  novelCoverFor    Novel?        @relation("NovelCover")
  chapterCoverFor  NovelChapter? @relation("NovelChapterCover")
}

model Lorebook {
  id               String                  @id @default(cuid())
  title            String
  slug             String                  @unique
  description      String?
  visibilityStatus ArchiveVisibilityStatus @default(DRAFT)
  isPublished      Boolean                 @default(false)

  coverImageId String?       @unique
  coverImage   ArchiveImage? @relation("LorebookCover", fields: [coverImageId], references: [id], onDelete: SetNull)

  contentSections    Json?
  linkedWorldIds     Json?
  linkedLocationIds  Json?
  linkedCharacterIds Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Novel {
  id               String                  @id @default(cuid())
  title            String
  slug             String                  @unique
  authorName       String
  summary          String?
  visibilityStatus ArchiveVisibilityStatus @default(DRAFT)
  isPublished      Boolean                 @default(false)

  coverImageId String?       @unique
  coverImage   ArchiveImage? @relation("NovelCover", fields: [coverImageId], references: [id], onDelete: SetNull)

  tags          Json?
  linkedWorldId String?
  linkedWorld   WorldEntry? @relation(fields: [linkedWorldId], references: [id], onDelete: SetNull)

  chapters NovelChapter[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NovelChapter {
  id      String @id @default(cuid())
  novelId String
  novel   Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)

  title      String
  slug       String
  subtitle   String?
  orderIndex Int
  status     NovelChapterStatus @default(DRAFT)

  coverImageId String?       @unique
  coverImage   ArchiveImage? @relation("NovelChapterCover", fields: [coverImageId], references: [id], onDelete: SetNull)

  contentBlocks Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([novelId, slug])
  @@unique([novelId, orderIndex])
}

model LocationEntry {
  id             String             @id @default(cuid())
  name           String
  slug           String             @unique
  description    String?
  locationType   LocationType
  originType     LocationOriginType
  canonStatus    WorldCanonStatus?
  orderIndex     Int?
  coordinateNote String?

  infoSections Json?
  notes        Json?

  parentWorldId String?
  parentWorld   WorldEntry? @relation("WorldEntryLocations", fields: [parentWorldId], references: [id], onDelete: Cascade)

  parentLocationId String?
  parentLocation   LocationEntry?  @relation("LocationHierarchy", fields: [parentLocationId], references: [id], onDelete: Cascade)
  children         LocationEntry[] @relation("LocationHierarchy")

  bannerImageId String?         @unique
  bannerImage   LocationImage?  @relation("LocationBanner", fields: [bannerImageId], references: [id], onDelete: SetNull)
  images        LocationImage[] @relation("LocationImages")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentWorldId])
  @@index([parentLocationId])
  @@index([locationType])
}

model LocationImage {
  id         String  @id @default(cuid())
  url        String
  storageKey String?
  caption    String?
  altText    String?
  isPrimary  Boolean @default(false)
  sortOrder  Int     @default(0)

  bannerFor  LocationEntry? @relation("LocationBanner")
  locationId String?
  location   LocationEntry? @relation("LocationImages", fields: [locationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model WorldEntry {
  id               String                @id @default(cuid())
  name             String
  slug             String                @unique
  description      String?
  summary          String?
  type             WorldEntryType
  canonStatus      WorldCanonStatus?
  cosmologyType    WorldCosmologyType?
  visibilityStatus WorldVisibilityStatus @default(DRAFT)
  isPublished      Boolean               @default(false)

  infoSections Json?
  notes        Json?

  sourceNote        String?
  installmentOrder  Int?
  installmentCode   String?
  inspirationNote   String?
  officialPublisher String?
  creator           String?
  branchDescription String?
  divergenceNote    String?
  approvalNote      String?
  sourceSeriesNote  String?

  isStandaloneContainer   Boolean?
  allowOriginalCreations  Boolean?
  allowOfficialSeries     Boolean?
  hasMultipleContinuities Boolean?
  isFullyIndependent      Boolean?
  officialCrossover       Boolean?

  parentId String?
  parent   WorldEntry?  @relation("WorldEntryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children WorldEntry[] @relation("WorldEntryHierarchy")

  bannerImageId String?           @unique
  bannerImage   WorldEntryImage?  @relation("WorldEntryBanner", fields: [bannerImageId], references: [id], onDelete: SetNull)
  images        WorldEntryImage[] @relation("WorldEntryImages")

  tags            WorldEntryTag[]
  linkedAbilities WorldEntryAbility[]

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  crossoverSources WorldEntrySource[] @relation("WorldEntrySourceOwner")
  usedInCrossovers WorldEntrySource[] @relation("WorldEntrySourceTarget")
  locations        LocationEntry[]    @relation("WorldEntryLocations")
  novels           Novel[]

  @@index([type])
  @@index([parentId])
  @@index([visibilityStatus])
}

model WorldEntryImage {
  id         String  @id @default(cuid())
  url        String
  storageKey String?
  caption    String?
  altText    String?
  isPrimary  Boolean @default(false)
  sortOrder  Int     @default(0)

  bannerFor    WorldEntry? @relation("WorldEntryBanner")
  worldEntryId String?
  worldEntry   WorldEntry? @relation("WorldEntryImages", fields: [worldEntryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model WorldEntryTag {
  id           String     @id @default(cuid())
  label        String
  worldEntryId String
  worldEntry   WorldEntry @relation(fields: [worldEntryId], references: [id], onDelete: Cascade)

  @@index([worldEntryId])
}

model WorldEntrySource {
  id            String @id @default(cuid())
  worldEntryId  String
  sourceEntryId String

  worldEntry  WorldEntry @relation("WorldEntrySourceOwner", fields: [worldEntryId], references: [id], onDelete: Cascade)
  sourceEntry WorldEntry @relation("WorldEntrySourceTarget", fields: [sourceEntryId], references: [id], onDelete: Cascade)

  @@unique([worldEntryId, sourceEntryId])
  @@index([worldEntryId])
  @@index([sourceEntryId])
}

model WorldEntryAbility {
  id            String @id @default(cuid())
  worldEntryId  String
  abilityNodeId String

  worldEntry  WorldEntry  @relation(fields: [worldEntryId], references: [id], onDelete: Cascade)
  abilityNode AbilityNode @relation(fields: [abilityNodeId], references: [id], onDelete: Cascade)

  @@unique([worldEntryId, abilityNodeId])
  @@index([worldEntryId])
  @@index([abilityNodeId])
}

model AbilityNode {
  id     String            @id @default(cuid())
  name   String
  slug   String            @unique
  type   AbilityNodeType
  status AbilityNodeStatus @default(DRAFT)

  family                AbilityFamilyType?
  shortDescriptionParts Json?
  notes                 Json?
  hierarchyLevel        String?
  isActive              Boolean            @default(false)

  contentSections Json?

  parentId String?
  parent   AbilityNode?  @relation("AbilityTree", fields: [parentId], references: [id], onDelete: SetNull)
  children AbilityNode[] @relation("AbilityTree")

  sourcesFrom   AbilityAssociationSource[] @relation("AssociationResult")
  sourcesUsedBy AbilityAssociationSource[] @relation("AssociationSource")

  mainImageId String?
  mainImage   AbilityNodeImage?  @relation("MainAbilityImage", fields: [mainImageId], references: [id], onDelete: SetNull)
  images      AbilityNodeImage[] @relation("AbilityNodeImages")

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  worldEntryAbilities WorldEntryAbility[]

  @@index([type])
  @@index([family])
  @@index([status])
  @@index([parentId])
  @@index([name])
}

model AbilityAssociationSource {
  id String @id @default(cuid())

  resultNodeId String
  sourceNodeId String

  resultNode AbilityNode @relation("AssociationResult", fields: [resultNodeId], references: [id], onDelete: Cascade)
  sourceNode AbilityNode @relation("AssociationSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([resultNodeId, sourceNodeId])
  @@index([resultNodeId])
  @@index([sourceNodeId])
}

model AbilityNodeImage {
  id            String       @id @default(cuid())
  abilityNodeId String?
  abilityNode   AbilityNode? @relation("AbilityNodeImages", fields: [abilityNodeId], references: [id], onDelete: Cascade)

  usedAsMainBy AbilityNode[] @relation("MainAbilityImage")

  url        String
  storageKey String?
  altText    String?
  caption    String?
  sortOrder  Int     @default(0)
  isPrimary  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([abilityNodeId])
  @@index([sortOrder])
}

model Verse {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  scaleTierId Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scaleTier  ScaleTier    @relation(fields: [scaleTierId], references: [id], onDelete: Restrict)
  genres     VerseGenre[]
  characters Character[]
}

model Genre {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  verses VerseGenre[]
}

model VerseGenre {
  verseId Int
  genreId Int

  verse Verse @relation(fields: [verseId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([verseId, genreId])
}

model Character {
  id         Int      @id @default(autoincrement())
  name       String
  verseId    Int
  isCanon    Boolean  @default(true)
  isOriginal Boolean  @default(false)
  isUncanon  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  verse Verse @relation(fields: [verseId], references: [id], onDelete: Cascade)
}

model ScaleTier {
  id          Int          @id @default(autoincrement())
  title       String       @unique
  slug        String       @unique
  tierCode    String
  tierName    String
  category    String
  subTier     ScaleSubTier
  hasPlus     Boolean      @default(false)
  sortOrder   Int          @unique
  dimension   String?
  description String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  verses Verse[]
}

enum ScaleSubTier {
  LOW
  MEDIUM
  HIGH
}
